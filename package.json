{
  "name": "pt2-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build:web": "vite build",
    "build:wasm": "powershell -ExecutionPolicy Bypass -File ./scripts/build-wasm.ps1",
    "build:synth-wasm": "powershell -ExecutionPolicy Bypass -File ./scripts/build-synth-wasm.ps1",
    "build": "npm run build:wasm && npm run build:synth-wasm && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide": "^0.542.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vue-tsc": "^3.2.5"
  }
}
